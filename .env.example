# ── Copy this to .env and fill in the blanks ──────────────────────────────────
# cp .env.example .env
# Then run: bash scripts/init.sh to auto-generate secrets

# ── Network ───────────────────────────────────────────────────────────────────
# Your machine's hostname — used for mDNS access from other devices on the LAN.
# Other devices reach the assistant at http://$HOSTNAME.local/
# Defaults to the system hostname if unset. Override if needed.
HOSTNAME=

# ── Security (generate with: openssl rand -hex 32) ────────────────────────────
SECRET_KEY=
ENCRYPTION_KEY_SECRET=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Note: Onyx defaults the user to "postgres" internally
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── LLM Model (Ollama) ────────────────────────────────────────────────────────
# Primary model used for chat + RAG responses
LLM_MODEL=llama4:scout
# Lightweight model for fast operations (classification, routing)
LLM_FAST_MODEL=llama4:scout

# ── App ───────────────────────────────────────────────────────────────────────
# Set to your server's public URL in production (e.g., https://ai.yourdomain.com)
WEB_DOMAIN=http://localhost

# AUTH_TYPE options: basic | google_oauth | saml | oidc
# Note: "disabled" is no longer supported in current Onyx versions
AUTH_TYPE=basic

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: debug | info | warning | error
LOG_LEVEL=info

# ── Voice Service ─────────────────────────────────────────────────────────────
# Onyx API key for voice service authentication.
# Create one in the Onyx admin panel: Settings → API Keys → New API Key
ONYX_API_KEY=
