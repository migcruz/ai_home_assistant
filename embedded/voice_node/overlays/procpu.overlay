/* Enable IPM for PRO CPU ↔ APP CPU inter-processor communication */
&ipm0 {
	status = "okay";
};

/*
 * BOOT button — GPIO0 (strapping pin, active-low, internal pull-up).
 * Used as the user record button until wake word (Milestone 5) replaces it.
 */
/ {
	aliases {
		sw0 = &boot_button;
	};

	buttons {
		compatible = "gpio-keys";
		boot_button: boot_button_0 {
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "BOOT";
		};
	};
};
